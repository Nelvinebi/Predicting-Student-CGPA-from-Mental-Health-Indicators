#!/usr/bin/env python3
"""
Species-Distribution-Modeling-with-Environmental-Variables (Synthetic)
----------------------------------------------------------------------

Generates synthetic environmental predictors on a grid, simulates species
occurrence probabilities from ecological response curves, samples
presence/absence, trains ML models (Logistic Regression & Random Forest),
evaluates performance, and exports artifacts.

Requirements:
  - Python 3.8+
  - numpy, pandas, scikit-learn, matplotlib

Usage:
  python sdm_synthetic.py --rows 40 --cols 40 --seed 42 --out outputs
"""

import os
import math
import argparse
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.model_selection import train_test_split
from sklearn.metrics import (
    roc_auc_score, roc_curve, average_precision_score, precision_recall_curve,
    confusion_matrix, accuracy_score, f1_score
)
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from sklearn.inspection import permutation_importance, PartialDependenceDisplay

RNG = np.random.default_rng(42)


def sigmoid(z):
    return 1.0 / (1.0 + np.exp(-z))


def generate_environment(rows=40, cols=40, seed=42):
    """
    Create a synthetic landscape with environmental variables on a regular grid.
    Returns a DataFrame with one row per cell and a metadata dict.
    """
    rng = np.random.default_rng(seed)

    # Grid (normalized coords)
    x = np.linspace(0, 1, cols)
    y = np.linspace(0, 1, rows)
    xx, yy = np.meshgrid(x, y)

    # Topography: rolling hills
    elev = 0.4 * np.sin(2*np.pi*xx) * np.cos(2*np.pi*yy) + 0.6*yy
    elev = (elev - elev.min()) / (elev.max() - elev.min())

    # Slope proxy from gradients
    gy, gx = np.gradient(elev)
    slope = np.sqrt(gx**2 + gy**2)
    slope = (slope - slope.min()) / (slope.max() - slope.min() + 1e-9)

    # Temperature (°C): warmer at lower elevation + latitudinal gradient
    temp = 30 - 8*elev - 3*(yy - 0.5) + 0.6*rng.normal(size=xx.shape)

    # Precipitation (mm): wetter in the "west" and at mid-elevations
    precip = 900 + 400*(1-xx) + 150*np.exp(-((elev-0.5)/0.25)**2) + 30*rng.normal(size=xx.shape)

    # NDVI-like greenness: favor moderate temp & higher precip
    ndvi = (
        0.7*np.exp(-0.5*((temp - 26)/4.5)**2) +
        0.3*(precip - precip.min())/(precip.max()-precip.min() + 1e-9)
    )
    ndvi += 0.05*rng.normal(size=ndvi.shape)
    ndvi = np.clip(ndvi, 0, 1)

    # Distance to a meandering river (simple vertical distance to curve)
    river = 0.55 + 0.12*np.sin(4*np.pi*xx)
    dist_to_water = np.abs(yy - river)  # in normalized units (0..~0.7)

    # Human footprint (urban cores) via two RBF centers
    def rbf(cx, cy, scale):
        return np.exp(-(((xx - cx)**2 + (yy - cy)**2) / (2 * scale**2)))
    human_fp = 0.9*rbf(0.25, 0.35, 0.12) + 0.8*rbf(0.75, 0.70, 0.10)
    human_fp += 0.05*rng.normal(size=human_fp.shape)
    human_fp = (human_fp - human_fp.min())/(human_fp.max()-human_fp.min() + 1e-9)

    # Assemble DataFrame
    df = pd.DataFrame({
        "x": xx.ravel(),
        "y": yy.ravel(),
        "elevation": elev.ravel(),
        "slope": slope.ravel(),
        "temperature": temp.ravel(),
        "precipitation": precip.ravel(),
        "ndvi": ndvi.ravel(),
        "dist_to_water": dist_to_water.ravel(),
        "human_footprint": human_fp.ravel(),
    })
    meta = {"rows": rows, "cols": cols}
    return df, meta


def simulate_occurrence(df, seed=42, target_prevalence=0.35):
    """
    Convert environmental variables to occurrence probability using
    simple ecological response curves, then sample presence/absence.
    """
    rng = np.random.default_rng(seed)

    # Preferences (Gaussian optima)
    temp_opt, temp_sd = 26.0, 4.0
    prec_opt, prec_sd = 1100.0, 250.0
    elev_opt, elev_sd = 0.45, 0.25

    suit_temp = np.exp(-0.5*((df["temperature"] - temp_opt)/temp_sd)**2)
    suit_prec = np.exp(-0.5*((df["precipitation"] - prec_opt)/prec_sd)**2)
    suit_elev = np.exp(-0.5*((df["elevation"] - elev_opt)/elev_sd)**2)
    suit_ndvi = df["ndvi"]  # already in 0..1
    suit_water = np.exp(-df["dist_to_water"]/0.08)  # decays with distance
    suit_human = 1 - df["human_footprint"]          # prefers low human footprint
    suit_slope = np.exp(-df["slope"]/0.25)          # gentle slopes preferred

    # Combine (weighted linear predictor)
    z = (
        1.6*suit_temp +
        1.4*suit_prec +
        1.2*suit_elev +
        1.8*suit_ndvi +
        1.0*suit_water +
        1.3*suit_human +
        0.6*suit_slope +
        0.2*rng.normal(size=len(df))
    )

    # Shift to hit target prevalence approximately
    mu = z.mean()
    def logit(p): return np.log(p/(1-p))
    bias = logit(target_prevalence) - mu
    p_occ = sigmoid(z + bias)

    y = rng.uniform(size=len(df)) < p_occ
    df = df.copy()
    df["occurrence_prob_true"] = p_occ
    df["presence"] = y.astype(int)
    return df


def evaluate_and_plot(models, X_train, X_test, y_train, y_test, feature_names, out_dir):
    """Evaluate models, save ROC/PR plots, feature importance and PDPs for RF."""
    os.makedirs(out_dir, exist_ok=True)

    # ROC & PR curves
    plt.figure(figsize=(6,5))
    for name, mdl in models.items():
        s = mdl.predict_proba(X_test)[:,1]
        fpr, tpr, _ = roc_curve(y_test, s)
        auc = roc_auc_score(y_test, s)
        plt.plot(fpr, tpr, label=f"{name} (AUC={auc:.3f})")
    plt.plot([0,1],[0,1], linestyle="--")
    plt.xlabel("False Positive Rate"); plt.ylabel("True Positive Rate")
    plt.title("ROC Curves")
    plt.legend(loc="lower right")
    plt.tight_layout(); plt.savefig(os.path.join(out_dir, "roc_curves.png"), dpi=200); plt.close()

    plt.figure(figsize=(6,5))
    for name, mdl in models.items():
        s = mdl.predict_proba(X_test)[:,1]
        prec, rec, _ = precision_recall_curve(y_test, s)
        ap = average_precision_score(y_test, s)
        plt.plot(rec, prec, label=f"{name} (AP={ap:.3f})")
    plt.xlabel("Recall"); plt.ylabel("Precision")
    plt.title("Precision-Recall Curves")
    plt.legend(loc="lower left")
    plt.tight_layout(); plt.savefig(os.path.join(out_dir, "pr_curves.png"), dpi=200); plt.close()

    # Metrics summary
    lines = []
    for name, mdl in models.items():
        s = mdl.predict_proba(X_test)[:,1]
        y_pred = (s >= 0.5).astype(int)
        auc = roc_auc_score(y_test, s)
        ap = average_precision_score(y_test, s)
        acc = accuracy_score(y_test, y_pred)
        f1 = f1_score(y_test, y_pred)
        cm = confusion_matrix(y_test, y_pred)
        lines.append(f"{name:>14} | AUC={auc:.3f}  AP={ap:.3f}  ACC={acc:.3f}  F1={f1:.3f}\nCM=\n{cm}\n")
    with open(os.path.join(out_dir, "metrics.txt"), "w") as f:
        f.writelines(lines)

    # Permutation importance (RF only)
    if "RandomForest" in models:
        rf = models["RandomForest"]
        perm = permutation_importance(rf, X_test, y_test, n_repeats=10, random_state=42, n_jobs=-1)
        imp = (pd.DataFrame({
            "feature": feature_names,
            "importance_mean": perm.importances_mean,
            "importance_std": perm.importances_std
        })
        .sort_values("importance_mean", ascending=False))
        imp.to_csv(os.path.join(out_dir, "rf_permutation_importance.csv"), index=False)

        plt.figure(figsize=(7,6))
        plt.barh(imp["feature"][::-1], imp["importance_mean"][::-1])
        plt.xlabel("Permutation Importance (mean decrease in AUC proxy)")
        plt.title("RandomForest Feature Importance")
        plt.tight_layout(); plt.savefig(os.path.join(out_dir, "rf_feature_importance.png"), dpi=200); plt.close()

        # Partial dependence for top 3
        top3 = imp["feature"].head(3).tolist()
        fig_list = []
        for feat in top3:
            fig = plt.figure(figsize=(5.5,4.5))
            try:
                PartialDependenceDisplay.from_estimator(rf, X_test, [feature_names.index(feat)], feature_names=feature_names, grid_resolution=50)
                plt.title(f"PDP: {feat}")
                plt.tight_layout()
                fig_path = os.path.join(out_dir, f"pdp_{feat}.png")
                plt.savefig(fig_path, dpi=200); plt.close()
                fig_list.append(fig_path)
            except Exception as e:
                plt.close()
                print(f"PDP failed for {feat}: {e}")

    return lines


def plot_maps(meta, df, proba_pred, out_dir):
    """Save heatmaps for true suitability, predicted probability, and presence points."""
    r, c = meta["rows"], meta["cols"]
    os.makedirs(out_dir, exist_ok=True)

    def imsave(Z, title, fname, cmap=None, vmin=None, vmax=None):
        plt.figure(figsize=(6,5))
        im = plt.imshow(Z.reshape(r, c), origin="lower", vmin=vmin, vmax=vmax, cmap=cmap)
        plt.title(title); plt.colorbar(im, shrink=0.8)
        plt.tight_layout(); plt.savefig(os.path.join(out_dir, fname), dpi=200); plt.close()

    imsave(df["occurrence_prob_true"].values, "True Occurrence Probability", "map_true_prob.png")
    imsave(proba_pred, "Predicted Occurrence Probability (RF)", "map_pred_prob_rf.png")
    imsave(df["ndvi"].values, "NDVI", "map_ndvi.png", vmin=0, vmax=1)

    # Presence point overlay on true prob
    plt.figure(figsize=(6,5))
    plt.imshow(df["occurrence_prob_true"].values.reshape(r,c), origin="lower")
    yy, xx = (df["y"].values.reshape(r,c), df["x"].values.reshape(r,c))
    pres = df["presence"].values.reshape(r,c)
    ys, xs = np.where(pres == 1)
    plt.scatter(xs, ys, s=6, c="white", marker="o", linewidths=0.3, edgecolors="black")
    plt.title("Presence Points on True Probability")
    plt.tight_layout(); plt.savefig(os.path.join(out_dir, "presence_overlay.png"), dpi=200); plt.close()


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--rows", type=int, default=40, help="Grid rows (>10).")
    ap.add_argument("--cols", type=int, default=40, help="Grid cols (>10).")
    ap.add_argument("--seed", type=int, default=42, help="Random seed.")
    ap.add_argument("--out",  type=str, default="outputs", help="Output folder.")
    args = ap.parse_args()

    os.makedirs(args.out, exist_ok=True)

    # 1) Generate environment & simulate species
    env_df, meta = generate_environment(args.rows, args.cols, seed=args.seed)
    df = simulate_occurrence(env_df, seed=args.seed, target_prevalence=0.35)

    # Ensure >100 points
    if len(df) <= 100:
        raise ValueError(f"Dataset too small ({len(df)}). Increase --rows/--cols.")

    # Save dataset
    csv_path = os.path.join(args.out, "sdm_synthetic_dataset.csv")
    xlsx_path = os.path.join(args.out, "sdm_synthetic_dataset.xlsx")
    df.to_csv(csv_path, index=False)
    try:
        df.to_excel(xlsx_path, index=False)  # requires openpyxl
    except Exception as e:
        print(f"Excel export skipped ({e}). CSV saved at {csv_path}")

    # 2) Train/test split
    FEATURES = ["x","y","elevation","slope","temperature","precipitation","ndvi","dist_to_water","human_footprint"]
    TARGET = "presence"
    X = df[FEATURES].values
    y = df[TARGET].values

    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.25, random_state=args.seed, stratify=y
    )

    # 3) Train models
    logit = LogisticRegression(max_iter=1000)
    logit.fit(X_train, y_train)

    rf = RandomForestClassifier(
        n_estimators=500, max_depth=None, min_samples_leaf=1,
        random_state=args.seed, n_jobs=-1, class_weight=None
    )
    rf.fit(X_train, y_train)

    models = {"Logistic": logit, "RandomForest": rf}

    # 4) Evaluate & plot curves/importance
    metrics_lines = evaluate_and_plot(models, X_train, X_test, y_train, y_test, FEATURES, args.out)

    # 5) Probability map from RF over full grid
    proba_pred_rf = rf.predict_proba(X)[:,1]
    plot_maps(meta, df, proba_pred_rf, args.out)

    # 6) Print summary
    print(f"Synthetic SDM dataset saved to:\n  - {csv_path}\n  - {xlsx_path} (if openpyxl available)")
    print("Metrics:\n" + "".join(metrics_lines))
    print(f"Artifacts in '{args.out}': roc_curves.png, pr_curves.png, rf_feature_importance.png, "
          f"pdp_*.png, map_true_prob.png, map_pred_prob_rf.png, presence_overlay.png, metrics.txt")


if __name__ == "__main__":
    main()
